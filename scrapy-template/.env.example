# Scrapy Configuration
SCRAPY_PROJECT=myproject
LOG_LEVEL=INFO
CONCURRENT_REQUESTS=16
DOWNLOAD_DELAY=1.0
AUTOTHROTTLE_ENABLED=true
ROBOTSTXT_OBEY=true

# Database Configuration
DATABASE_URL=postgresql://scrapy:changeme@localhost:5432/scrapy
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=scrapy
POSTGRES_USER=scrapy
POSTGRES_PASSWORD=changeme

# MongoDB Configuration (alternative)
MONGO_URI=mongodb://localhost:27017/
MONGO_DATABASE=scrapy

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# API Keys and Services
SCRAPEOPS_API_KEY=your_scrapeops_api_key_here
SENTRY_DSN=your_sentry_dsn_here

# Proxy Configuration
PROXY_ENABLED=false
PROXY_URL=http://proxy.example.com:8080
PROXY_USER=
PROXY_PASS=
ROTATING_PROXY_LIST_PATH=

# Browser Automation (Playwright)
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSER_TYPE=chromium

# Data Export
EXPORT_FORMAT=json
EXPORT_DIR=data
FEEDS_ENABLED=true

# Security and Rate Limiting
USER_AGENT_ROTATION=true
RESPECT_ROBOTS_TXT=true
DOWNLOAD_TIMEOUT=30
DNS_TIMEOUT=10

# Monitoring
STATS_ENABLED=true
TELNETCONSOLE_ENABLED=false
MEMUSAGE_ENABLED=true
MEMUSAGE_LIMIT_MB=512

# Development
DEBUG=false
HTTPCACHE_ENABLED=false
HTTPCACHE_DIR=httpcache
