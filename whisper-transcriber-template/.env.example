# Whisper Transcriber Configuration

# Default Whisper model (tiny, base, small, medium, large-v3)
WHISPER_MODEL=base

# Device to use (cpu, cuda, auto)
WHISPER_DEVICE=auto

# Compute type (int8, float16, int8_float16)
# CPU: use int8
# GPU: use float16 or int8_float16
WHISPER_COMPUTE_TYPE=int8

# Default output format (txt, srt, vtt, json)
DEFAULT_OUTPUT_FORMAT=txt

# Output directory for transcripts (default: same directory as input)
OUTPUT_DIR=

# Temporary directory for extracted audio files
TMP_DIR=./tmp

# Language (leave empty for auto-detection)
# Examples: en, fr, de, es, ja, zh
WHISPER_LANGUAGE=

# VAD (Voice Activity Detection) filter - removes silence
VAD_FILTER=true

# Beam size for transcription (1=fastest, 10=most accurate)
BEAM_SIZE=5
