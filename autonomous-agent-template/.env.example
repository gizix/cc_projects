# ─── Core ────────────────────────────────────────────────────────────────────
# Master password for the encrypted credential store
# REQUIRED at runtime: set this or you'll be prompted interactively
MASTER_PASSWORD=change-me-to-something-strong

# Directory for SQLite databases and credential store
DATA_DIR=data

# Worker threads for the task executor
WORKER_THREADS=4

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ─── Web Dashboard ───────────────────────────────────────────────────────────
WEB_HOST=127.0.0.1
WEB_PORT=7890

# ─── LLM: Azure OpenAI (Primary) ─────────────────────────────────────────────
# Get these from Azure Portal → Azure OpenAI → Keys and Endpoint
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ─── LLM: OpenAI (Fallback) ──────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ─── LLM: Local / OpenAI-Compatible (Ollama, LM Studio) ─────────────────────
# Set base URL to use a local model instead of cloud APIs
# OPENAI_BASE_URL=http://localhost:11434/v1   # Ollama
# OPENAI_BASE_URL=http://localhost:1234/v1    # LM Studio
# OPENAI_API_KEY=ollama                        # Required but ignored

# ─── External Database (Optional) ────────────────────────────────────────────
# Any SQLAlchemy-compatible URL for reading/writing external data
# EXTERNAL_DB_URL=postgresql://user:password@localhost:5432/mydb
# EXTERNAL_DB_URL=mysql+pymysql://user:password@localhost:3306/mydb
# EXTERNAL_DB_URL=sqlite:///path/to/external.db

# ─── Docker ──────────────────────────────────────────────────────────────────
# Set to 1 to disable OS automation (reminder, text_fill, program_launcher)
# AGENT_HEADLESS=1
