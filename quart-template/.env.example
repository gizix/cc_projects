# Quart Application Environment Variables
# Copy this file to .env and update with your values

# ============================================================================
# Application Configuration
# ============================================================================

# Environment: development, testing, production
QUART_ENV=development

# Secret key for session encryption (CHANGE IN PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# ============================================================================
# Database Configuration
# ============================================================================

# SQLite (default for development)
DATABASE_URL=sqlite+aiosqlite:///./app.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname

# MySQL
# DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/dbname

# ============================================================================
# JWT Authentication
# ============================================================================

# JWT secret key (CHANGE IN PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production

# JWT algorithm (default: HS256)
JWT_ALGORITHM=HS256

# ============================================================================
# CORS Configuration
# ============================================================================

# Allowed origins (comma-separated, no spaces)
# Development: Use "*" for all origins (not secure)
# Production: Specify exact origins
CORS_ALLOWED_ORIGINS=*

# Production example:
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ============================================================================
# Rate Limiting
# ============================================================================

# Enable/disable rate limiting
RATE_LIMIT_ENABLED=false

# Default rate limit (format: "X per Y" where Y is minute/hour/day)
RATE_LIMIT_DEFAULT=100 per hour

# ============================================================================
# Logging
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# ============================================================================
# Application Settings
# ============================================================================

# Background task shutdown timeout (seconds)
BACKGROUND_TASK_SHUTDOWN_TIMEOUT=30

# Default pagination page size
DEFAULT_PAGE_SIZE=20

# Maximum pagination page size
MAX_PAGE_SIZE=100

# ============================================================================
# External Services (Optional)
# ============================================================================

# Redis (for caching, rate limiting, etc.)
# REDIS_URL=redis://localhost:6379/0

# Email SMTP (for sending emails)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=noreply@example.com

# Sentry (error tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# Development Settings (not needed in production)
# ============================================================================

# Quart development server settings
QUART_APP=src.app:create_app()
QUART_DEBUG=1

# ============================================================================
# Production Settings (only for production)
# ============================================================================

# Number of Hypercorn workers (recommended: 2 * CPU cores + 1)
# WORKERS=4

# Bind address and port
# BIND=0.0.0.0:8000
